    "/storeproduct/transfer": {
        "post": {
            "description": "Realiza una transferencia gratuita de productos desde el stock central hacia una tienda específica. Útil para movimientos internos sin transacción comercial.",
            "operationId": "StoreProductController_transferStock",
            "parameters": [],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "TransferStockDto"
                        }
                    }
                }
            },
            "responses": {
                "201": {
                    "description": "Transferencia realizada exitosamente."
                },
                "400": {
                    "description": "Stock insuficiente o datos inválidos."
                },
                "404": {
                    "description": "Tienda o Producto no encontrado."
                },
                "default": {
                    "description": ""
                }
            },
            "summary": "Transferir stock de la central a una tienda",
            "tags": ["Productos de la Tienda"]
        }
    },
    "/storeproduct/inventory": {
        "get": {
            "description": "Obtiene el listado completo de productos en stock de una tienda específica, incluyendo cantidades, costos de compra y precios de venta.",
            "operationId": "StoreProductController_getStoreInventory",
            "parameters": [
                {
                    "name": "storeID",
                    "required": true,
                    "in": "query",
                    "description": "ID de la tienda para consultar inventario",
                    "schema": {
                        "type": "string"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "Inventario de la tienda.",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "array",
                                "items": {
                                    "$ref": "Product"
                                }
                            }
                        }
                    }
                },
                "default": {
                    "description": "",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "array",
                                "items": {
                                    "$ref": "Product"
                                }
                            }
                        }
                    }
                }
            },
            "summary": "Consultar inventario de una tienda",
            "tags": ["Productos de la Tienda"]
        }
    },
    "/storeproduct/{id}": {
        "patch": {
            "description": "Permite actualizar el stock, precio de costo y precio de venta de un producto en una tienda específica usando su StoreProductID.",
            "operationId": "StoreProductController_update",
            "parameters": [
                {
                    "name": "id",
                    "required": true,
                    "in": "path",
                    "description": "ID del StoreProduct a actualizar",
                    "schema": {
                        "type": "string"
                    }
                }
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "UpdateStoreProductDto"
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "Producto de tienda actualizado exitosamente.",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "StoreProduct"
                            }
                        }
                    }
                },
                "404": {
                    "description": "Producto de tienda no encontrado."
                },
                "default": {
                    "description": "",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "StoreProduct"
                            }
                        }
                    }
                }
            },
            "summary": "Actualizar un producto en tienda (Inventario/Precios)",
            "tags": ["Productos de la Tienda"]
        }
    },
