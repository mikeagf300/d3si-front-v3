    "/store-monthly-targets/{storeID}": {
        "get": {
            "operationId": "StoreMonthlyTargetsController_getByStore",
            "parameters": [
                {
                    "name": "storeID",
                    "required": true,
                    "in": "path",
                    "description": "ID de la tienda",
                    "schema": {
                        "type": "string"
                    }
                },
                {
                    "name": "period",
                    "required": false,
                    "in": "path",
                    "description": "Periodo opcional. Si no se envía, se usa el mes actual. Formatos aceptados: YYYY-MM-DD, YYYY-MM, YYYY/MM/DD, YYYY/MM",
                    "schema": {
                        "type": "string"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "Meta mensual (0 si no existe)."
                },
                "404": {
                    "description": "Tienda no encontrada."
                },
                "default": {
                    "description": "",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "number"
                            }
                        }
                    }
                }
            },
            "summary": "Obtener la meta mensual de una tienda por ID. period opcional: YYYY-MM-DD, YYYY-MM o YYYY/MM/DD, YYYY/MM",
            "tags": ["Metas Mensuales de Tienda"]
        },
        "post": {
            "operationId": "StoreMonthlyTargetsController_upsert",
            "parameters": [
                {
                    "name": "storeID",
                    "required": true,
                    "in": "path",
                    "description": "ID de la tienda",
                    "schema": {
                        "type": "string"
                    }
                }
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "UpsertStoreMonthlyTargetDto"
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "Meta creada o actualizada.",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "StoreMonthlyTarget"
                            }
                        }
                    }
                },
                "default": {
                    "description": "",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "StoreMonthlyTarget"
                            }
                        }
                    }
                }
            },
            "summary": "Crear o actualizar la meta mensual para la tienda en el periodo dado (por defecto mes actual).",
            "tags": ["Metas Mensuales de Tienda"]
        }
    },
    "/store-monthly-targets/{id}": {
        "patch": {
            "description": "Solo permite editar metas del mes actual o de meses futuros.",
            "operationId": "StoreMonthlyTargetsController_update",
            "parameters": [
                {
                    "name": "id",
                    "required": true,
                    "in": "path",
                    "description": "ID de la meta mensual",
                    "schema": {
                        "type": "string"
                    }
                }
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "UpdateStoreMonthlyTargetDto"
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "Meta mensual actualizada exitosamente.",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "StoreMonthlyTarget"
                            }
                        }
                    }
                },
                "400": {
                    "description": "La meta pertenece a un mes pasado o el payload es inválido."
                },
                "default": {
                    "description": "",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "StoreMonthlyTarget"
                            }
                        }
                    }
                }
            },
            "summary": "Actualizar una meta mensual",
            "tags": ["Metas Mensuales de Tienda"]
        },
        "delete": {
            "description": "Solo permite eliminar metas del mes actual o de meses futuros.",
            "operationId": "StoreMonthlyTargetsController_remove",
            "parameters": [
                {
                    "name": "id",
                    "required": true,
                    "in": "path",
                    "description": "ID de la meta mensual",
                    "schema": {
                        "type": "string"
                    }
                }
            ],
            "responses": {
                "204": {
                    "description": "Meta mensual eliminada exitosamente."
                },
                "default": {
                    "description": ""
                }
            },
            "summary": "Eliminar una meta mensual",
            "tags": ["Metas Mensuales de Tienda"]
        }
    }
}
