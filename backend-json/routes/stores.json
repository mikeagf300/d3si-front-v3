        "patch": {
            "description": "Modifica los datos de una tienda existente (nombre, dirección, teléfono, etc.).",
            "operationId": "StoresController_update",
            "parameters": [
                {
                    "name": "id",
                    "required": true,
                    "in": "path",
                    "description": "ID de la tienda",
                    "schema": {
                        "type": "string"
                    }
                }
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "UpdateStoreDto"
                        }
                    }
