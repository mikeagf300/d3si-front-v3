    "/userstores/{id}": {
        "get": {
            "description": "Retorna todas las tiendas a las que un usuario tiene acceso.",
            "operationId": "UserstoresController_findOne",
            "parameters": [
                {
                    "name": "id",
                    "required": true,
                    "in": "path",
                    "description": "ID de la relación usuario-tienda",
                    "schema": {
                        "type": "string"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "Lista de tiendas del usuario.",
