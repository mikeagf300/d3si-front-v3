            },
            "responses": {
                "200": {
                    "description": "Tienda actualizada exitosamente.",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "Store"
                            }
                        }
                    }
                },
                "404": {
                    "description": "Tienda no encontrada."
                },
                "default": {
                    "description": "",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "Store"
                            }
                        }
                    }
                }
            },
            "summary": "Actualizar información de una tienda",
