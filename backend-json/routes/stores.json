{
    "/stores": {
        "post": {
            "description": "Registra una nueva tienda en el sistema. Puede ser de tipo central, franquicia, consignación o terceros.",
            "operationId": "StoresController_create",
            "parameters": [],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "CreateStoreDto"
                        }
                    }
                }
            },
            "responses": {
                "201": {
                    "description": "Tienda creada exitosamente.",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "Store"
                            }
                        }
                    }
                },
                "400": {
                    "description": "Datos inválidos o email/nombre duplicado."
                },
                "default": {
                    "description": "",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "Store"
                            }
                        }
                    }
                }
            },
            "summary": "Crear una nueva tienda",
            "tags": ["Tiendas"]
        },
        "get": {
            "description": "Retorna el listado completo de tiendas registradas en el sistema.",
            "operationId": "StoresController_findAll",
            "parameters": [],
            "responses": {
                "200": {
                    "description": "Lista de tiendas.",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "array",
                                "items": {
                                    "$ref": "Store"
                                }
                            }
                        }
                    }
                },
                "default": {
                    "description": "",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "array",
                                "items": {
                                    "$ref": "Store"
                                }
                            }
                        }
                    }
                }
            },
            "summary": "Obtener todas las tiendas",
            "tags": ["Tiendas"]
        }
    },
    "/stores/{id}/users": {
        "get": {
            "operationId": "StoresController_findUsersByStoreId",
            "parameters": [
                {
                    "name": "id",
                    "required": true,
                    "in": "path",
                    "description": "ID de la tienda",
                    "schema": {
                        "type": "string"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "Lista de usuarios de la tienda.",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "array",
                                "items": {
                                    "$ref": "User"
                                }
                            }
                        }
                    }
                },
                "404": {
                    "description": "Tienda no encontrada."
                },
                "default": {
                    "description": "",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object"
                            }
                        }
                    }
                }
            },
            "summary": "Obtener todos los usuarios de una tienda",
            "tags": ["Tiendas"]
        }
    },
    "/stores/{id}": {
        "get": {
