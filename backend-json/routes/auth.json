{
    "/auth/login": {
        "post": {
            "operationId": "AuthController_login",
            "parameters": [],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "LoginDto"
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "Inicio de sesión exitoso"
                },
                "401": {
                    "description": "Credenciales inválidas"
                },
                "default": {
                    "description": ""
                }
            },
            "summary": "Autenticar usuario y devolver JWT",
            "tags": ["Autenticación"]
        }
    },
    "/auth/check-status": {
        "get": {
            "operationId": "AuthController_checkAuthStatus",
            "parameters": [],
            "responses": {
                "200": {
                    "description": "Token válido"
                },
                "401": {
                    "description": "No autorizado"
                },
                "default": {
                    "description": ""
                }
            },
            "summary": "Verificar estado de la autenticación y devolver un nuevo JWT",
            "tags": ["Autenticación"]
        }
    }
}
