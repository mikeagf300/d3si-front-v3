{
    "/inventory/movements": {
        "post": {
            "description": "Registra una entrada o salida manual de stock para un producto específico en una tienda.",
            "operationId": "InventoryController_createMovement",
            "parameters": [],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "CreateInventoryMovementDto"
                        }
                    }
                }
            },
            "responses": {
                "201": {
                    "description": "El movimiento de inventario ha sido registrado exitosamente."
                },
                "400": {
                    "description": "Datos de entrada inválidos o stock insuficiente."
                },
                "default": {
                    "description": "",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "InventoryMovement"
                            }
                        }
                    }
                }
            },
            "summary": "Crear un movimiento de inventario manual",
            "tags": ["Inventario"]
        }
    },
    "/inventory/store/{storeID}": {
        "get": {
            "description": "Devuelve la lista de productos y sus cantidades actuales para la tienda solicitada.",
            "operationId": "InventoryController_getStoreStock",
            "parameters": [
                {
                    "name": "storeID",
                    "required": true,
                    "in": "path",
                    "description": "ID de la tienda (UUID)",
                    "schema": {
                        "type": "string"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "Lista de inventario recuperada exitosamente."
                },
                "404": {
                    "description": "Tienda no encontrada."
                },
                "default": {
                    "description": "",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "array",
                                "items": {
                                    "$ref": "StoreProduct"
                                }
                            }
                        }
                    }
                }
            },
            "summary": "Obtener el stock de una tienda específica",
            "tags": ["Inventario"]
        }
    },
    "/transfers": {
        "post": {
            "description": "Inicia un proceso de transferencia entre una tienda origen y una tienda destino.",
            "operationId": "TransfersController_createTransfer",
            "parameters": [],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "CreateStoreTransferDto"
                        }
                    }
                }
            },
            "responses": {
                "201": {
                    "description": "La transferencia ha sido creada en estado borrador."
                },
                "400": {
                    "description": "Datos de entrada inválidos."
                },
                "default": {
                    "description": "",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "StoreTransfer"
                            }
                        }
                    }
                }
            },
            "summary": "Crear una nueva transferencia en borrador",
            "tags": ["Transferencias entre Tiendas"]
        }
    },
    "/transfers/{id}/items": {
        "post": {
            "description": "Añade un item con su cantidad a una transferencia que aún no ha sido completada.",
            "operationId": "TransfersController_addItem",
            "parameters": [
                {
                    "name": "id",
                    "required": true,
                    "in": "path",
                    "description": "ID de la transferencia (UUID)",
                    "schema": {
                        "type": "string"
                    }
                }
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "AddTransferItemDto"
                        }
                    }
                }
            },
            "responses": {
                "201": {
                    "description": "Producto agregado exitosamente a la transferencia."
                },
                "404": {
                    "description": "Transferencia no encontrada."
                },
                "default": {
                    "description": "",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "StoreTransferItem"
                            }
                        }
                    }
                }
            },
            "summary": "Agregar un producto a una transferencia pendiente",
            "tags": ["Transferencias entre Tiendas"]
        }
    },
    "/transfers/{id}/complete": {
        "post": {
            "description": "Finaliza la transferencia, validando el stock en origen y realizando el movimiento físico de mercancía.",
            "operationId": "TransfersController_completeTransfer",
            "parameters": [
                {
                    "name": "id",
                    "required": true,
                    "in": "path",
                    "description": "ID de la transferencia a completar (UUID)",
                    "schema": {
                        "type": "string"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "Transferencia completada y stock actualizado en ambas tiendas."
                },
                "400": {
                    "description": "Error al completar la transferencia (ej. stock insuficiente)."
                },
                "404": {
                    "description": "Transferencia no encontrada."
                },
                "default": {
                    "description": "",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "StoreTransfer"
                            }
                        }
                    }
                }
            },
            "summary": "Completar transferencia y mover stock",
            "tags": ["Transferencias entre Tiendas"]
        }
    },
    "/transfers/{id}": {
        "get": {
            "operationId": "TransfersController_getTransfer",
            "parameters": [
                {
                    "name": "id",
                    "required": true,
                    "in": "path",
                    "description": "ID de la transferencia (UUID)",
                    "schema": {
                        "type": "string"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "Detalles de la transferencia recuperados exitosamente."
                },
                "404": {
                    "description": "Transferencia no encontrada."
                },
                "default": {
                    "description": "",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object"
                            }
                        }
                    }
                }
            },
            "summary": "Obtener detalles de una transferencia",
            "tags": ["Transferencias entre Tiendas"]
        }
    }
}
