{
    "/sales": {
        "post": {
            "description": "Registra una nueva venta para una tienda específica. Si la tienda es Central, se descuenta del stock global de variaciones. Si es una tienda asociada (franquicia, etc.), se descuenta del stock local de la tienda (StoreProduct).",
            "operationId": "SalesController_create",
            "parameters": [],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "CreateSaleDto"
                        }
                    }
                }
            },
            "responses": {
                "201": {
                    "description": "Venta creada exitosamente.",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "Sale"
                            }
                        }
                    }
                },
                "400": {
                    "description": "Stock insuficiente o datos inválidos."
                },
                "404": {
                    "description": "Tienda o Producto no encontrado."
                },
                "default": {
                    "description": "",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "Sale"
                            }
                        }
                    }
                }
            },
            "summary": "Registrar una venta",
            "tags": ["Ventas"]
        },
        "get": {
            "description": "Retorna un listado de todas las ventas realizadas, ordenadas por fecha de creación (más recientes primero).",
            "operationId": "SalesController_findAll",
            "parameters": [],
            "responses": {
                "200": {
                    "description": "Lista de ventas.",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "array",
                                "items": {
                                    "$ref": "Sale"
                                }
                            }
                        }
                    }
                },
                "default": {
                    "description": "",
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "array",
                                "items": {
                                    "$ref": "Sale"
                                }
                            }
                        }
                    }
                }
            },
            "summary": "Obtener todas las ventas registradas",
            "tags": ["Ventas"]
        }
    },
    "/sales/{id}": {
        "get": {
            "description": "Retorna la información completa de una venta incluyendo productos, cantidades, precios y estado.",
            "operationId": "SalesController_findOne",
            "parameters": [
                {
                    "name": "id",
                    "required": true,
                    "in": "path",
                    "description": "ID de la venta",
                    "schema": {
                        "type": "string"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "Venta encontrada.",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "Sale"
                            }
                        }
                    }
                },
                "404": {
                    "description": "Venta no encontrada."
                },
                "default": {
                    "description": "",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "Sale"
                            }
                        }
                    }
                }
            },
            "summary": "Obtener detalle de una venta específica",
            "tags": ["Ventas"]
        }
    },
    "/sales/{id}/status": {
        "patch": {
            "description": "Permite cambiar el estado de una venta entre Pendiente, Pagado o Anulado.",
            "operationId": "SalesController_updateStatus",
            "parameters": [
                {
                    "name": "id",
                    "required": true,
                    "in": "path",
                    "description": "ID de la venta",
                    "schema": {
                        "type": "string"
                    }
                }
            ],
            "requestBody": {
                "required": true,
                "content": {
                    "application/json": {
                        "schema": {
                            "$ref": "UpdateSaleStatusDto"
                        }
                    }
                }
            },
            "responses": {
                "200": {
                    "description": "Estado actualizado exitosamente.",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "Sale"
                            }
                        }
                    }
                },
                "default": {
                    "description": "",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "Sale"
                            }
                        }
                    }
                }
            },
            "summary": "Actualizar el estado de una venta",
            "tags": ["Ventas"]
        }
    },
    "/reports/sales": {
        "get": {
            "description": "Obtiene resumen de ventas agrupadas por tipo de pago y estado, resúmenes de periodo (hoy, ayer, mes) y listado de ventas dentro del rango. Fechas en ISO 8601.",
            "operationId": "ReportsController_salesReport",
            "parameters": [
                {
                    "name": "storeId",
                    "required": true,
                    "in": "query",
                    "description": "ID de la tienda para filtrar",
                    "schema": {
                        "example": "store-uuid",
                        "type": "string"
                    }
                },
                {
                    "name": "from",
                    "required": false,
                    "in": "query",
                    "description": "Fecha desde (inclusive) ISO 8601",
                    "schema": {
                        "type": "string"
                    }
                },
                {
                    "name": "to",
                    "required": false,
                    "in": "query",
                    "description": "Fecha hasta (exclusive) ISO 8601",
                    "schema": {
                        "type": "string"
                    }
                },
                {
                    "name": "page",
                    "required": false,
                    "in": "query",
                    "description": "Página (paginación) - default 1",
                    "schema": {
                        "minimum": 1,
                        "default": 1,
                        "example": 1,
                        "type": "number"
                    }
                },
                {
                    "name": "limit",
                    "required": false,
                    "in": "query",
                    "description": "Tamaño de página - default 50",
                    "schema": {
                        "minimum": 1,
                        "default": 50,
                        "example": 50,
                        "type": "number"
                    }
                }
            ],
            "responses": {
                "200": {
                    "description": "Reporte de ventas",
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "SalesReportDto"
                            }
                        }
                    }
                },
                "default": {
                    "description": ""
                }
            },
            "summary": "Reporte de ventas",
            "tags": ["Reportes"]
        }
    }
}
