{
    "SaleProductItemDto": {
        "type": "object",
        "properties": {
            "variationID": {
                "type": "string",
                "format": "uuid",
                "description": "ID de la variación del producto a vender",
                "example": "123e4567-e89b-12d3-a456-426614174000"
            },
            "quantity": {
                "type": "number",
                "minimum": 1,
                "description": "Cantidad de unidades a vender",
                "example": 10
            },
            "unitPrice": {
                "type": "number",
                "minimum": 0,
                "description": "Precio unitario de venta",
                "example": 15000
            }
        },
        "required": ["variationID", "quantity", "unitPrice"]
    },
    "CreateSaleDto": {
        "type": "object",
        "properties": {
            "storeID": {
                "type": "string",
                "format": "uuid",
                "description": "ID de la tienda que realiza la compra",
                "example": "123e4567-e89b-12d3-a456-426614174001"
            },
            "paymentType": {
                "type": "string",
                "enum": ["Efectivo", "Debito", "Credito"],
                "description": "Método de pago utilizado para la transacción",
                "example": "Credito"
            },
            "items": {
                "description": "Lista de productos y cantidades a vender",
                "example": [
                    {
                        "variationID": "123e4567-e89b-12d3-a456-426614174000",
                        "quantity": 10,
                        "unitPrice": 15000
                    }
                ],
                "type": "array",
                "items": {
                    "$ref": "#/components/schemas/SaleProductItemDto"
                }
            }
        },
        "required": ["storeID", "paymentType", "items"]
    },
    "Sale": {
        "type": "object",
        "properties": {
            "saleID": {
                "type": "string"
            },
            "store": {
                "$ref": "#/components/schemas/Store"
            },
            "status": {
                "type": "object"
            },
            "total": {
                "type": "number"
            },
            "paymentType": {
                "type": "object"
            },
            "saleProducts": {
                "type": "array",
                "items": {
                    "$ref": "#/components/schemas/SaleProduct"
                }
            },
            "createdAt": {
                "format": "date-time",
                "type": "string"
            },
            "updatedAt": {
                "format": "date-time",
                "type": "string"
            }
        },
        "required": ["saleID", "store", "status", "total", "paymentType", "saleProducts", "createdAt", "updatedAt"]
    },
    "SaleProduct": {
        "type": "object",
        "properties": {
            "saleProductID": {
                "type": "string"
            },
            "sale": {
                "$ref": "#/components/schemas/Sale"
            },
            "variation": {
                "$ref": "#/components/schemas/ProductVariation"
            },
            "unitPrice": {
                "type": "number"
            },
            "subtotal": {
                "type": "number"
            },
            "quantitySold": {
                "type": "number"
            },
            "createdAt": {
                "format": "date-time",
                "type": "string"
            },
            "updatedAt": {
                "format": "date-time",
                "type": "string"
            }
        },
        "required": [
            "saleProductID",
            "sale",
            "variation",
            "unitPrice",
            "subtotal",
            "quantitySold",
            "createdAt",
            "updatedAt"
        ]
    },
    "UpdateSaleStatusDto": {
        "type": "object",
        "properties": {
            "status": {
                "type": "string",
                "enum": ["Pagado", "Pendiente", "Anulado"],
                "description": "Nuevo estado de la venta. Pagado: transacción completada, Pendiente: esperando pago, Anulado: venta cancelada",
                "example": "Pagado"
            }
        },
        "required": ["status"]
    }
}
